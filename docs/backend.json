{
  "entities": {
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message sent in the live community chat room.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the message."
        },
        "senderId": {
          "type": "string",
          "description": "The unique ID of the sender."
        },
        "senderName": {
          "type": "string",
          "description": "The display name of the sender."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the sender's avatar."
        }
      },
      "required": ["text", "senderId", "senderName", "timestamp"]
    },
    "PrivateMessage": {
      "title": "PrivateMessage",
      "description": "A private message between two users.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The message content."
        },
        "senderId": {
          "type": "string",
          "description": "UID of the sender."
        },
        "receiverId": {
          "type": "string",
          "description": "UID of the receiver."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        },
        "chatId": {
          "type": "string",
          "description": "Combined ID of the two participants (sorted UIDs)."
        }
      },
      "required": ["text", "senderId", "receiverId", "timestamp", "chatId"]
    },
    "ChatThread": {
      "title": "ChatThread",
      "description": "Metadata for a private conversation thread.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string", "format": "date-time" },
        "participantNames": { "type": "object" },
        "participantAvatars": { "type": "object" }
      }
    },
    "Bid": {
      "title": "Bid",
      "description": "A record of a bid placed on an auction listing.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "bidderId": { "type": "string" },
        "bidderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "bidderId", "bidderName", "timestamp"]
    },
    "Review": {
      "title": "Review",
      "description": "Feedback left by a buyer for a seller after a transaction.",
      "type": "object",
      "properties": {
        "listingId": {
          "type": "string"
        },
        "sellerId": {
          "type": "string"
        },
        "buyerId": {
          "type": "string"
        },
        "rating": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "comment": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["listingId", "sellerId", "buyerId", "rating", "comment", "timestamp"]
    },
    "Listing": {
      "title": "Listing",
      "description": "A collectible item listed for sale or auction.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currentBid": { "type": "number" },
        "bidCount": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Sold", "Ended"] },
        "type": { "type": "string", "enum": ["Auction", "Buy It Now"] },
        "endsAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingType": { "type": "string", "enum": ["Free", "Paid"] },
        "shippingCost": { "type": "number" },
        "weight": { "type": "number" },
        "length": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["title", "price", "sellerId", "status", "type"]
    },
    "Giveaway": {
      "title": "Giveaway",
      "description": "A prize draw hosted by a dealer.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Ended"] },
        "endsAt": { "type": "string", "format": "date-time" },
        "entriesCount": { "type": "number" },
        "prizeValue": { "type": "number" }
      },
      "required": ["title", "sellerId", "status", "endsAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed purchase transaction and tracking record.",
      "type": "object",
      "properties": {
        "listingId": { "type": "string" },
        "listingTitle": { "type": "string" },
        "imageUrl": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["Confirmed", "Processing", "Shipped", "Delivered"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "trackingNumber": { "type": "string" }
      },
      "required": ["listingId", "buyerId", "sellerId", "status", "price"]
    },
    "Storefront": {
      "title": "Storefront",
      "description": "Public appearance settings for a dealer's storefront.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "theme": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "isSpotlighted": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Follower": {
      "title": "Follower",
      "description": "A relationship between a user and a storefront they follow.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "storefrontUsername": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "An alert for a user about platform activity.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["Message", "Outbid", "System"] },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Report": {
      "title": "Report",
      "description": "A flag raised against a user, listing, or storefront.",
      "type": "object",
      "properties": {
        "reportedId": { "type": "string" },
        "reportedName": { "type": "string" },
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "type": { "type": "string", "enum": ["User", "Listing", "Storefront"] },
        "status": { "type": "string", "enum": ["Pending", "Resolved"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ISORequest": {
      "title": "ISORequest",
      "description": "An 'In Search Of' request posted by a collector.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "budget": { "type": "number" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "postedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Searching", "Found"] }
      }
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Collection of global community chat messages."
    },
    "/private_chats/{chatId}": {
      "schema": "ChatThread",
      "description": "Metadata for private conversations."
    },
    "/private_chats/{chatId}/messages/{messageId}": {
      "schema": "PrivateMessage",
      "description": "Individual messages within a private conversation."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Public reviews for sellers."
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Publicly viewable listings."
    },
    "/listings/{listingId}/bids/{bidId}": {
      "schema": "Bid",
      "description": "History of bids for a specific auction."
    },
    "/giveaways/{giveawayId}": {
      "schema": "Giveaway",
      "description": "Publicly viewable giveaways."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Records of completed purchases."
    },
    "/storefronts/{username}": {
      "schema": "Storefront",
      "description": "Identity and theme settings for individual storefront profiles."
    },
    "/followers/{followerId}": {
      "schema": "Follower",
      "description": "List of user-to-storefront follows."
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User-specific alerts."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Platform-wide flags for moderation."
    },
    "/iso_requests/{requestId}": {
      "schema": "ISORequest",
      "description": "Community hunt requests that expire every 24 hours."
    }
  }
}
