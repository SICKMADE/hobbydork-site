rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /storeAvatars/{ownerUid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }

    match /storeImages/{ownerUid}/{storeId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }

    // User profile pictures
    match /avatars/{ownerUid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }

    match /listingImages/{ownerUid}/{listingId}/{imageFilename} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }

    match /iso24Images/{ownerUid}/{isoId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }


    // Store Giveaway images
    match /giveawayImages/{ownerUid}/{giveawayId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }
    


    // Storefront banner image
    match /storefronts/{storeId}/store-banner.jpg {
      allow read: if true;
      // Allow authenticated users to write (permission check happens in Firestore rules)
      allow write: if request.auth != null;
    }

    // Listing images (new path)
    match /listings/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Platform bounties
    match /platformBounties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}