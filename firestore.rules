/**
 * HobbyDork Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a hybrid security model designed for a public marketplace. It uses 
 * Structural Segregation to separate private draft content from public listings and utilizes
 * Denormalization for Authorization to ensure high performance without complex relational lookups.
 *
 * Data Structure:
 * - /users/{userId}: Public profiles (Self-edit only).
 * - /categories & /tags: Global read-only metadata (Admin-only writes).
 * - /listings: Public marketplace listings.
 * - /users/{userId}/draft_listings: Private workspace for sellers.
 * - /purchases & /transactions: Private financial records restricted to involved parties.
 *
 * Key Security Decisions:
 * 1. Authorization Independence: Critical ownership data (e.g., sellerId) is denormalized 
 *    onto sub-resources like photos and bids to avoid expensive get() calls.
 * 2. Drafting vs. Publishing: Drafts are kept in user-specific subcollections (`/users/{userId}/draft_listings`)
   for strict path-based isolation. Once a draft is published to the top-level `/listings` collection, they follow 
 *    public-read/owner-write rules. Storefronts are the public-facing seller pages (formerly called shops).
 * 3. Relational Integrity: On creation, rules enforce that the user's ID is correctly 
 *    stamped onto the document, and these fields are made immutable during updates.
 * 4. Admin Access: Administrative privileges are determined by the existence of a 
 *    document in the /roles_admin/ collection.
 */

rules_version = '2';

service cloud.firestore {

  // ---------------- HELPERS ----------------
  function isSignedIn() {
    return request.auth != null;
  }

  function uid() {
    return request.auth.uid;
  }

  function userData() {
    return get(/databases/(default)/documents/users/$(uid())).data;
  }

  function userExists() {
    return isSignedIn() && userData() != null;
  }

  function userIsActive() {
    return userExists() && userData().status == "ACTIVE";
  }

  function userIsAdmin() {
    return userExists() && userData().role == "ADMIN";
  }

  function userIsStaff() {
    return userExists() && (userData().role == "ADMIN" || userData().role == "MODERATOR");
  }

  function userIsSeller() {
    return userExists() && userData().isSeller == true;
  }

  function isVerified() {
    let data = userData();
    return userExists()
      && data.status == "ACTIVE"
      && data.emailVerified == true;
  }

  function isAdminDoc() {
    // Allow admin access if user has role 'ADMIN' or has a /roles_admin/{uid} doc
    return userIsAdmin() || exists(/databases/(default)/documents/roles_admin/$(uid()));
  }

  function isConversationParticipant(conversationId) {
    let convo = get(/databases/(default)/documents/conversations/$(conversationId)).data;
    return convo.participantUids.hasAny([uid()]);
  }

  // ---------------- ROOT ----------------
  match /databases/{database}/documents {

    // -------- USERS --------
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSignedIn() && uid() == userId;
      allow delete: if userIsAdmin();

      match /notifications/{id} {
        allow read, write: if uid() == userId;
      }

      match /watchlist/{id} {
        allow read, write: if uid() == userId;
      }

      match /favoriteStores/{id} {
        allow read, write: if uid() == userId;
      }

      match /storefronts/{storeId} {
        allow read, write: if uid() == userId;
      }

      match /draft_listings/{draftId} {
        allow read, write: if uid() == userId;
      }

      match /feeTransactions/{feeId} {
        allow get, list: if uid() == userId;
        allow create: if uid() == userId;
        allow update, delete: if isAdminDoc();
      }

      match /themePurchases/{purchaseId} {
        allow get, list: if uid() == userId;
        allow create: if uid() == userId;
        allow update: if uid() == userId;
        allow delete: if isAdminDoc();
      }
    }

    // -------- USERNAMES --------
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn();
    }

    // -------- FOLLOWERS --------
    match /followers/{id} {
      allow get, list: if true;
    }

    // -------- LISTINGS --------
    match /listings/{listingId} {
      allow get, list: if true;

      allow create: if userIsSeller() && isVerified()
        && request.resource.data.sellerId == uid()
        && request.resource.data.title is string
        && request.resource.data.price is number
        && request.resource.data.price >= 0;

      // --- COLLECTION GROUP RULE FOR POSTS ---
      match /{path=**}/posts/{postId} {
        allow get, list: if true;
      // -------- STORE --------
      match /store/{storeId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.ownerUid == uid();
        allow update, delete: if resource.data.ownerUid == uid();
      }
        allow create: if isVerified();
        allow update, delete: if isVerified() && resource.data.ownerUid == uid();
      }
      allow update: if userIsSeller()
        && resource.data.sellerId == uid()
        && request.resource.data.sellerId == resource.data.sellerId;

      allow delete: if resource.data.sellerId == uid() || userIsStaff();

      match /bids/{bidId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdminDoc();
      }
    }

    // -------- STOREFRONTS --------
    match /storefronts/{storeId} {
      allow get, list: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == uid();

      allow update, delete: if isSignedIn()
        && resource.data.ownerUid == uid();
      
        // --- POSTS SUBCOLLECTION ---
        match /posts/{postId} {
          allow get, list: if true;
          allow create: if isVerified() && request.resource.data.ownerUid == uid();
          allow update, delete: if isVerified() && resource.data.ownerUid == uid();
        }
        // --- FEEDS SUBCOLLECTION ---
        match /feeds/{feedId} {
          allow get, list: if true;
        }
    }

    // -------- FEEDS --------
    match /storefronts/{storeId}/feeds/{feedId} {
      allow get, list: if true;

      allow create: if isVerified()
        && request.resource.data.authorUid == uid();

      allow update, delete: if resource.data.authorUid == uid();

      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isVerified()
          && request.resource.data.authorUid == uid();
        allow update, delete: if resource.data.authorUid == uid();
      }

      match /likes/{likeId} {
        allow get, list: if true;
        allow create: if isSignedIn()
          && request.resource.data.userUid == uid();
        allow delete: if resource.data.userUid == uid();
      }
    }

    // -------- GIVEAWAYS --------
    match /giveaways/{giveawayId} {
      allow get, list: if true;

      allow create: if userIsSeller() && isVerified()
        && request.resource.data.sellerId == uid();

      allow update, delete: if resource.data.sellerId == uid() || userIsStaff();

      match /giveawayEntries/{entryId} {
        allow create: if isVerified()
          && request.resource.data.userId == uid();

        allow get: if uid() == resource.data.userId
          || uid() == resource.data.sellerId
          || userIsStaff();
      }
    }

    // -------- PLATFORM BOUNTIES --------
    match /platformBounties/{bountyId} {
      allow get, list: if true;
      allow create, update, delete: if isAdminDoc();
    }

    match /platformBountyEntries/{entryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isVerified();
    }

    // -------- SELLER APPLICATIONS --------
    match /sellerApplications/{id} {
      allow get, list, update, delete: if isAdminDoc();
      allow create: if isSignedIn() && request.resource.data.ownerUid == uid();
    }

    // -------- PAYOUT REQUESTS --------
    match /payoutRequests/{id} {
      allow get, list: if isAdminDoc() || resource.data.ownerUid == uid();
      allow create: if isVerified()
        && request.resource.data.ownerUid == uid();
      allow update, delete: if isAdminDoc();
    }

    // -------- CUSTOM THEMES --------
    match /customThemeRequests/{id} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == uid();
      allow update, delete: if isAdminDoc();
    }

    // -------- ORDERS --------
    match /orders/{orderId} {
      allow create: if userIsActive()
        && request.resource.data.buyerUid == uid();

      allow get, list: if userIsActive()
        && (resource.data.buyerUid == uid()
        || resource.data.sellerUid == uid()
        || userIsStaff());

      allow update: if userIsStaff()
        || (isSignedIn()
        && (resource.data.buyerUid == uid()
        || resource.data.sellerUid == uid()));
    }

    // -------- TRANSACTIONS --------
    match /transactions/{id} {
      allow read, write: if isSignedIn()
        && (resource.data.buyerUid == uid()
        || resource.data.sellerUid == uid());
    }

    match /purchases/{id} {
      allow read, write: if isSignedIn()
        && (resource.data.buyerUid == uid()
        || resource.data.sellerUid == uid());
    }


    // -------- ISO POSTS --------
    match /iso24Posts/{id} {
      allow get, list: if true;
      allow create, update, delete: if isVerified();
    }

    // -------- COMMUNITY --------
    match /communityMessages/{id} {
      allow get, list: if userIsActive();
      allow create: if isVerified();
    }

    // -------- CONVERSATIONS --------
    match /conversations/{conversationId} {
      allow create: if userIsActive();

      allow get, list: if userIsActive()
        && (isConversationParticipant(conversationId) || userIsStaff());

      match /messages/{messageId} {
        allow get, list, create: if isVerified()
          && isConversationParticipant(conversationId);
      }
    }

    // -------- REPORTS --------
    match /reports/{id} {
      allow create: if userIsActive()
        && request.resource.data.reporterUid == uid();

      allow get, list: if userIsStaff()
        || resource.data.reporterUid == uid();

      allow update: if userIsStaff();
      allow delete: if userIsAdmin();
    }

    // -------- LOGS --------
    match /auditLogs/{id} {
      allow read, write: if isAdminDoc();
    }

    match /errorLogs/{id} {
      allow create: if true;
      allow read, update, delete: if isAdminDoc();
    }

    // -------- REVIEWS --------
    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.authorUid == uid();
    }

    // -------- GLOBAL --------
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdminDoc();
    }

    match /tags/{id} {
      allow read: if true;
      allow write: if isAdminDoc();
    }

    // -------- LOCK EVERYTHING ELSE --------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}