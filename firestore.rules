rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData(userId) {
      let path = /databases/$(database)/documents/users/$(userId);
      return exists(path) ? get(path).data : null;
    }

    function isActive() {
      let userDocPath = /databases/$(database)/documents/users/$(uid());
      return isSignedIn() && isEmailVerified() && exists(userDocPath) && get(userDocPath).data.status == 'ACTIVE';
    }

    function isSeller() {
      let data = getUserData(uid());
      return isActive() && data != null && data.isSeller == true;
    }

    // --- COLLECTION GROUP RULES ---
    match /{path=**}/posts/{postId} {
      allow read: if true;
      allow create: if isActive();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false; 

      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;
      }
      
      match /watchlist/{itemId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSeller();
      allow update, delete: if isSignedIn() && resource.data.listingSellerId == uid();

      match /bids/{bidId} {
        allow read: if isSignedIn();
        allow create: if isActive() && request.resource.data.bidderId == uid();
      }
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn() && (resource.data.buyerUid == uid() || resource.data.sellerUid == uid());
      allow update: if isSignedIn() && (resource.data.buyerUid == uid() || resource.data.sellerUid == uid());
    }

    match /iso24Posts/{postId} {
      allow read: if true;
      allow create: if isActive();
      allow update, delete: if isSignedIn() && resource.data.uid == uid();
    }

    match /storefronts/{storeId} {
      allow read: if true;
      allow update: if isSignedIn() && resource.data.ownerUid == uid();
      allow create: if isSeller();

      match /posts/{postId} {
        allow read: if true;
        allow create: if isActive() && get(/databases/$(database)/documents/storefronts/$(storeId)).data.ownerUid == uid();
      }
    }

    match /giveaways/{giveawayId} {
      allow read: if true;
      allow create: if isSeller();
      allow update: if isSignedIn() && resource.data.sellerId == uid();

      match /giveawayEntries/{entryId} {
        allow read: if isSignedIn();
        allow create: if isActive() && entryId == uid();
      }
    }

    match /communityMessages/{msgId} {
      allow read: if true;
      allow create: if isActive();
    }

    match /followers/{followId} {
      allow read: if true;
      allow write: if isSignedIn() && followId.startsWith(uid());
    }
    
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn();
    }
    
    match /conversations/{convId} {
      allow read: if isSignedIn() && uid() in resource.data.participantUids;
      allow create: if isActive();
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.participantUids;
        allow create: if isActive();
      }
    }
    
    match /reports/{reportId} {
      allow create: if isSignedIn();
    }
    
    match /payoutRequests/{requestId} {
      allow create: if isSeller();
      allow read: if isSignedIn() && (resource.data.sellerUid == uid() || getUserData(uid()).role == 'ADMIN');
    }
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isActive();
    }
  }
}