rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------- Helpers -------------

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Direct check to avoid recursion in users/{userId} match
    function isStaffByDoc() {
      let role = get(/databases/$(database)/documents/users/$(uid())).data.role;
      return role == "ADMIN" || role == "MODERATOR";
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function userIsActive() {
      let data = userData();
      return isSignedIn() && data != null && data.status == "ACTIVE";
    }

    function userIsAdmin() {
      let data = userData();
      return isSignedIn() && data != null && data.role == "ADMIN";
    }

    function userIsStaff() {
      let data = userData();
      return isSignedIn() && data != null && (data.role == "ADMIN" || data.role == "MODERATOR");
    }

    function isVerified() {
      let data = userData();
      return isSignedIn() && data != null && data.emailVerified == true && data.status == "ACTIVE";
    }

    function userIsSeller() {
      let data = userData();
      return isSignedIn() && data != null && data.isSeller == true;
    }

    function isConversationParticipant(conversationId) {
      let conversation = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
      return isSignedIn() && (
        conversation.participantUids.hasAny([uid()]) ||
        conversation.participants.hasAny([uid()])
      );
    }

    // ------------- users -------------

    match /users/{userId} {
      // Basic UID match first to avoid unnecessary get() calls
      allow get: if isSignedIn() && (uid() == userId || isStaffByDoc());
      allow list: if userIsStaff();
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSignedIn() && uid() == userId;
      allow delete: if userIsAdmin();

      match /notifications/{id} {
        allow read, write: if isSignedIn() && uid() == userId;
      }
      match /watchlist/{listingId} {
        allow read, write: if isSignedIn() && uid() == userId;
      }
      match /favoriteStores/{storeId} {
        allow read, write: if isSignedIn() && uid() == userId;
      }
      match /storefronts/{storeId} {
        allow read, write: if isSignedIn() && uid() == userId;
      }
    }

    // ------------- giveaways -------------
    match /giveaways/{giveawayId} {
      allow get, list: if true;
      allow create: if userIsSeller() && userIsActive() && request.resource.data.sellerId == uid();
      allow update: if (userIsSeller() && resource.data.sellerId == uid()) || userIsStaff();
      allow delete: if (userIsSeller() && resource.data.sellerId == uid()) || userIsStaff();

      match /giveawayEntries/{entryId} {
        allow get: if uid() == resource.data.userId || uid() == resource.data.sellerId || userIsStaff();
        allow list: if userIsStaff() || uid() == resource.data.sellerId || (get(/databases/$(database)/documents/giveaways/$(giveawayId)).data.status == 'picking');
        allow create: if isSignedIn() && request.resource.data.userId == uid() && userIsActive() && request.resource.data.isFollowing == true && !exists(/databases/$(database)/documents/giveaways/$(giveawayId)/giveawayEntries/$(uid()));
        allow update, delete: if userIsStaff();
      }
    }

    // ------------- storefronts -------------
    match /storefronts/{storeId} {
      allow get, list: if true;
      allow create: if isVerified();
      allow update: if isVerified() || (isSignedIn() && userIsSeller() && resource.data.ownerUid == uid());
      allow delete: if isVerified();
      
      match /reviews/{reviewId} {
        allow get, list, create, update, delete: if isVerified();
      }
    }

    // ------------- listings -------------
    match /listings/{listingId} {
      allow get, list: if true;
      
      allow create: if userIsSeller() && userIsActive() && isVerified() && 
        request.resource.data.sellerId == uid() &&
        // Validate required fields
        request.resource.data.title != null && request.resource.data.title is string &&
        request.resource.data.price != null && request.resource.data.price >= 0 &&
        request.resource.data.category != null && request.resource.data.category is string &&
        // Validate optional but important fields
        (!('condition' in request.resource.data) || 
          request.resource.data.condition in ['New', 'Like New', 'Used']) &&
        (!('visibility' in request.resource.data) || 
          request.resource.data.visibility in ['Visible', 'Invisible']) &&
        // Validate shipping fields if present
        (!('weight' in request.resource.data) || request.resource.data.weight == null || request.resource.data.weight >= 0) &&
        (!('length' in request.resource.data) || request.resource.data.length == null || request.resource.data.length >= 0) &&
        (!('width' in request.resource.data) || request.resource.data.width == null || request.resource.data.width >= 0) &&
        (!('height' in request.resource.data) || request.resource.data.height == null || request.resource.data.height >= 0) &&
        (!('shippingCost' in request.resource.data) || request.resource.data.shippingCost == null || request.resource.data.shippingCost >= 0) &&
        // Validate quantity if present (for Buy It Now listings)
        (!('quantity' in request.resource.data) || request.resource.data.quantity == null || (request.resource.data.quantity is number && request.resource.data.quantity >= 1));
      
      allow update: if (
        userIsSeller() && resource.data.sellerId == uid()
      ) &&
        // Validate updated fields
        (!('condition' in request.resource.data) || 
          request.resource.data.condition in ['New', 'Like New', 'Used']) &&
        (!('visibility' in request.resource.data) || 
          request.resource.data.visibility in ['Visible', 'Invisible']) &&
        // Validate shipping fields if present
        (!('weight' in request.resource.data) || request.resource.data.weight == null || request.resource.data.weight >= 0) &&
        (!('length' in request.resource.data) || request.resource.data.length == null || request.resource.data.length >= 0) &&
        (!('width' in request.resource.data) || request.resource.data.width == null || request.resource.data.width >= 0) &&
        (!('height' in request.resource.data) || request.resource.data.height == null || request.resource.data.height >= 0) &&
        (!('shippingCost' in request.resource.data) || request.resource.data.shippingCost == null || request.resource.data.shippingCost >= 0) &&
        // Validate quantity if present (for Buy It Now listings)
        (!('quantity' in request.resource.data) || request.resource.data.quantity == null || (request.resource.data.quantity is number && request.resource.data.quantity >= 1));
      
      allow delete: if (userIsSeller() && resource.data.sellerId == uid()) || userIsStaff();
    }

    // ------------- orders -------------
    match /orders/{orderId} {
      allow get, list: if userIsActive() && (userIsStaff() || resource.data.buyerUid == uid() || resource.data.sellerUid == uid());
      allow create: if userIsActive() && request.resource.data.buyerUid == uid() && request.resource.data.shippingAddress != null;
      
      // Restrict updates to safe fields only - status changes must go through callables
      allow update: if userIsStaff() || (
        isSignedIn() && 
        (resource.data.buyerUid == uid() || resource.data.sellerUid == uid()) &&
        // Only allow updating safe fields - prevent status/price/payment manipulation
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedback', 'notes', 'buyerNotes', 'sellerNotes', 'carrierDeliveryDate', 'lastTrackingCheck', 'updatedAt'])
      );
      
      allow delete: if userIsAdmin();
    }

    // ISO24 posts
    match /iso24Posts/{isoId} {
      allow get, list: if true;
      allow create, update, delete: if isVerified();
    }

    // Community chat
    match /communityMessages/{messageId} {
      allow get, list: if userIsActive();
      allow create: if isSignedIn() && (userIsActive() || userIsAdmin());
      allow update, delete: if userIsActive() && userIsStaff();
    }

    // Conversations and messages
    match /conversations/{conversationId} {
      allow create: if userIsActive() && request.resource.data.participantUids.hasAny([uid()]);
      allow get, list, update: if userIsActive() && (isConversationParticipant(conversationId) || userIsStaff());
      allow delete: if userIsAdmin();

      match /messages/{messageId} {
        allow get, list: if userIsActive() && (isConversationParticipant(conversationId) || userIsStaff());
        allow create: if userIsActive() && isConversationParticipant(conversationId);
        allow update, delete: if userIsActive() && (isConversationParticipant(conversationId) || userIsStaff());
      }
    }

    // Reports
    match /reports/{reportId} {
      allow create: if userIsActive() && request.resource.data.reporterUid == uid();
      allow get, list: if userIsActive() && (userIsStaff() || resource.data.reporterUid == uid());
      allow update: if userIsActive() && userIsStaff();
      allow delete: if userIsAdmin();
    }

    // Fallback
    match /{path=**} {
      allow read: if true;
      allow write: if isVerified() || (isSignedIn() && path.matches('users/.+'));
    }
  }
}
